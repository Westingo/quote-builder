# Python
__pycache__/
*.pyc
.venv/
venv/

# Generated proposals (job inputs are tracked; built .docx are not)
jobs/*/*.docx
jobs/*/~$*.docx
jobs/*/_preview.pdf

# OS / editor
Thumbs.db
desktop.ini
.DS_Store

# Word/OneDrive lock files
~$*

# runtime logs
desktop.log
desktop-error.log
jobs/*/_x.pdf
jobs/*/_p1.pdf

# Anthropic key for scan import (never commit)
api_key.txt

# Per-machine customer quotes stay local — only the template and Hoodland demo
# ship in the repo. New job folders won't be committed on any machine.
/jobs/*
!/jobs/_template
!/jobs/hoodland-tc
